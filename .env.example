# LLM Configuration
OPENAI_API_KEY=YOUR API KEY
LLM_PROVIDER=openai                  # openai | local
LOCAL_MODEL_PATH=models/llama        # used if LLM_PROVIDER=local

# Embedding Configuration
EMBEDDING_PROVIDER=sentence_transformers   # openai | sentence_transformers
EMBEDDING_MODEL=all-MiniLM-L6-v2          # ST model name
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Vector Store
VECTOR_STORE_PATH=vector_store/
FAISS_INDEX_NAME=main_index

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DEBUG=true

# Database (Optional)
DATABASE_URL=postgresql://username:password@localhost:5432/analytics_db

# Cache
CACHE_DIR=.cache
CACHE_TTL=3600

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs/
